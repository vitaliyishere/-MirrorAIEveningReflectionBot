TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here

# Опционально: если используешь Claude вместо GPT
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Твой Telegram user_id (чтобы бот работал только для тебя)
# Узнать можно через @userinfobot
ALLOWED_USER_ID=your_telegram_user_id_here

# Timezone для резюме в 22:00
TIMEZONE=Europe/Moscow

# Модель для рефлексии: gpt-4o или gpt-4o-mini
AI_MODEL=gpt-4o
